stage T(
    in  float v,
    out float w,
    src py    "t",
)

pipeline Q(
    in  float[] vs,
    in  bool    skip,
    out float[] w,
)
{
    map call T(
        v = split self.vs,
    ) using (
        disabled = self.skip,
    )

    return (
        w = T.w,
    )
}

call Q(
    vs   = [1.0],
    skip = false,
)
