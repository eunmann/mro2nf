stage S(
    in  int x,
    out int y,
    src py  "s",
)

# INNER contains a nested map call, so a map over INNER needs 2-D fork keying.
pipeline INNER(
    in  int[] xs,
    out int[] ys,
)
{
    map call S(
        x = split self.xs,
    )

    return (
        ys = S.y,
    )
}

pipeline P(
    in  int[][] sets,
    out int[][] y,
)
{
    map call INNER(
        xs = split self.sets,
    )

    return (
        y = INNER.ys,
    )
}

call P(
    sets = [
        [1],
    ],
)
