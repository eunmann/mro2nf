stage S(
    in  float x,
    out float y,
    src py    "s",
)

# INNER contains a disabled call, so it cannot be threaded per fork.
pipeline INNER(
    in  float x,
    in  bool  off,
    out float y,
)
{
    call S(
        x = self.x,
    ) using (
        disabled = self.off,
    )

    return (
        y = S.y,
    )
}

pipeline P(
    in  float[] xs,
    out float[] y,
)
{
    map call INNER(
        x   = split self.xs,
        off = false,
    )

    return (
        y = INNER.y,
    )
}

call P(
    xs = [1.0],
)
