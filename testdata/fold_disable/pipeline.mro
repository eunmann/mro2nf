# #59 Lever 1 regression: the entry bakes skip=true, so GEN's disabled=self.skip
# folds to always-off. With -fold-disables, GEN is pruned to its null output (no
# stage, no gate). USE is a downstream STAGE that consumes GEN's (null) output —
# it must resolve the same null the runtime-skip path produces (regression for
# the review's flagged case). KEEP always runs. Output is byte-identical to mrp
# either way.
stage GEN(
    out int y,
    src py "stages/gen",
)

stage USE(
    in  int y,
    out int w,
    src py "stages/use",
)

stage KEEP(
    out int z,
    src py "stages/keep",
)

pipeline P(
    in  bool skip,
    out int  y,
    out int  z,
    out int  w,
)
{
    call GEN() using (
        disabled = self.skip,
    )

    call USE(
        y = GEN.y,
    )

    call KEEP()

    return (
        y = GEN.y,
        z = KEEP.z,
        w = USE.w,
    )
}

call P(
    skip = true,
)
