stage SCALE(
    in  float value,
    in  float factor,
    out float scaled,
    src py    "stages/scale",
)

pipeline EF(
    in  float[] values,
    in  float   factor,
    out float[] scaled,
)
{
    map call SCALE(
        value  = split self.values,
        factor = self.factor,
    )

    return (
        scaled = SCALE.scaled,
    )
}

call EF(
    values = [],
    factor = 10.0,
)
