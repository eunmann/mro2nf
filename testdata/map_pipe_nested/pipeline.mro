# Nested map: OUTER maps INNER, and INNER itself maps DBL. 2-D fork keying.
stage DBL(
    in  int x,
    out int y,
    src py  "stages/dbl",
)

pipeline INNER(
    in  int[] xs,
    out int[] ys,
)
{
    map call DBL(
        x = split self.xs,
    )

    return (
        ys = DBL.y,
    )
}

pipeline OUTER(
    in  int[][] sets,
    out int[][] yss,
)
{
    map call INNER(
        xs = split self.sets,
    )

    return (
        yss = INNER.ys,
    )
}

call OUTER(
    sets = [
        [1, 2],
        [3],
    ],
)
